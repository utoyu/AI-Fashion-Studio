                                        swap_outfit: { icon: Shirt, label: "模特换装 (Outfit Change)" },
                                        swap_face: { icon: User, label: "模特换脸 (Face Swap)" },
                                        change_pose: { icon: Accessibility, label: "换姿势 (Pose Change)" }
                                    };
                                    const config = Labels[mode as keyof typeof Labels];
                                    return config ? (
