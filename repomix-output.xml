                                    <p className="text-white text-[10px] truncate font-medium flex-1 mr-2">{asset.title}</p>
                                    <Button size="sm" className="h-6 py-0 px-2 bg-primary hover:bg-primary text-[9px] scale-90">选用</Button>
                                </div>
                            </div>
                        ))}
                    </div>
                </DialogContent>
            </Dialog>
        </div>
    )
}
